# Normalise line endings so Visual Studio (Windows) and WSL agree.
# The whole team is on Windows + Visual Studio, so check out CRLF.
* text=auto

*.cs      text eol=crlf
*.csproj  text eol=crlf
*.sln     text eol=crlf
*.resx    text eol=crlf
*.config  text eol=crlf
*.sql     text eol=crlf
*.bat     text eol=crlf
*.md      text eol=crlf

# Treat these as binary (never try to merge/diff line endings)
*.png binary
*.jpg binary
*.ico binary
*.zip binary
